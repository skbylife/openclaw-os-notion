# mission-control.yaml
schema_version: "1.1"
database: mission_control

state_machine:
  states: [backlog, this_week, in_progress, waiting, done, cancelled]
  valid_transitions:
    backlog: [this_week, cancelled]
    this_week: [in_progress, backlog, cancelled]
    in_progress: [waiting, done, this_week, cancelled]
    waiting: [in_progress, cancelled]

fields:
  task:
    type: title
    required: true
  status:
    type: select
    default: backlog
    options:
      - {value: backlog, label: "🆕 Backlog"}
      - {value: this_week, label: "⚡ This Week"}
      - {value: in_progress, label: "🔄 In Progress"}
      - {value: waiting, label: "⏸ Waiting"}
      - {value: done, label: "✅ Done"}
      - {value: cancelled, label: "❌ Cancelled"}
  priority:
    type: select
    options: ["🔴 Urgent", "🟠 High", "🟡 Medium", "🟢 Low"]
  owner:
    type: select
    options: ["🤖 AI Agent", "👤 Master", "🤝 Both"]
  category:
    type: select
    options: [Research, Writing, Strategy, Technical, Income, Personal]
  due_date:
    type: date
  time_estimate:
    type: select
    options: ["15 min", "30 min", "1 hr", "2 hr", "Half Day", "Full Day"]
  progress:
    type: number
    format: percentage
```

